# Токен бота от @BotFather (обязательно)
BOT_TOKEN=123456789:AA...replace_me...

# ID чата, куда пересылать обратную связь (узнать свой id можно у @userinfobot).
# Можно оставить пустым — тогда фидбэк только сохраняется в БД.
ADMIN_CHAT_ID=

# Подключение к БД. По умолчанию — локальный SQLite-файл в ./data
DB_URL=sqlite+aiosqlite:///data/potracheno.db

# Часовой пояс по умолчанию (IANA), пока пользователь не выбрал свой в онбординге
DEFAULT_TZ=Europe/Moscow

# Время напоминаний по умолчанию (локальное, HH:MM)
DEFAULT_NOTIFY_TIME=10:00
